# Server Port
PORT=5000

# MongoDB Connection (Required for live DB, falls back to memory DB if omitted or connection fails)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/syncora?retryWrites=true&w=majority

# Authentication Options (Set to true to use Clerk, defaults to false for local demo authentication)
USE_CLERK=false
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Cloudinary File Storage (Used for task attachments in production)
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
